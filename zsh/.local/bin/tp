#!/usr/bin/env bash
# tp [path] — open or switch to a tmux project session
#   tp          fzf-pick from CODE_DIRS roots + running sessions
#                 Enter   = attach/open
#                 Ctrl-X  = kill highlighted session, reload list
#   tp .        use current directory
#   tp <path>   use that path
#
# When the chosen session doesn't already exist, prompts for a layout:
#   windows   3 windows (code / ai / term) — current default
#   ide       one window: nvim left, claude top-right, term + .trun panes bottom
# Set TP_LAYOUT=windows|ide in the env to skip the prompt.
set -euo pipefail

# Project roots to scan, space-separated. Override via the CODE_DIRS env var.
CODE_DIRS="${CODE_DIRS:-$HOME/Code $HOME/Code-Safad}"

_session_name() {
  basename "$1" | tr '[:upper:]' '[:lower:]' | tr ' .' '-'
}

# Print rows as TAB-separated: status<TAB>name<TAB>path<TAB>display
# Running sessions first (marked ●), then idle project entries.
# Path is empty for "session-only" rows (no matching dir under CODE_DIRS).
_list_rows() {
  local running_list
  running_list=$(tmux list-sessions -F '#S' 2>/dev/null | sort || true)

  # Build "name<TAB>dir" index for project dirs under each root in CODE_DIRS.
  local dir_index=""
  local d name root
  while IFS= read -r d; do
    [[ -z "$d" ]] && continue
    name=$(_session_name "$d")
    dir_index+="${name}	${d}"$'\n'
  done < <(
    for root in $CODE_DIRS; do
      [[ -d "$root" ]] || continue
      find "$root" -mindepth 1 -maxdepth 1 -type d
    done | sort
  )

  # Running sessions first — look up their dir from the index, if any.
  local s path note
  if [[ -n "$running_list" ]]; then
    while IFS= read -r s; do
      [[ -z "$s" ]] && continue
      path=""
      if [[ -n "$dir_index" ]]; then
        path=$(awk -F'\t' -v n="$s" '$1==n {print $2; exit}' <<< "$dir_index")
      fi
      note=""
      [[ -z "$path" ]] && note="  (session only)"
      printf '%s\t%s\t%s\t● %s%s\n' "RUNNING" "$s" "$path" "$s" "$note"
    done <<< "$running_list"
  fi

  # Idle dirs — those whose mapped session-name is not currently running.
  if [[ -n "$dir_index" ]]; then
    local idx_name idx_dir
    while IFS=$'\t' read -r idx_name idx_dir; do
      [[ -z "$idx_name" ]] && continue
      if [[ -n "$running_list" ]] \
         && awk -v n="$idx_name" '$0==n {found=1; exit} END {exit !found}' <<< "$running_list"; then
        continue
      fi
      printf '%s\t%s\t%s\t  %s\n' "IDLE" "$idx_name" "$idx_dir" "$(basename "$idx_dir")"
    done <<< "$dir_index"
  fi
}

_pick_row() {
  _list_rows | fzf \
    --prompt="project> " \
    --delimiter=$'\t' \
    --with-nth=4 \
    --header='enter: open  ·  ctrl-x: kill session' \
    --preview='if [ -n {3} ]; then eza --color=always {3}; else tmux list-windows -t "={2}" 2>/dev/null; fi' \
    --bind 'ctrl-x:execute-silent(tp --__kill {2})+reload(tp --__list)' \
    --height=50% \
    --border=rounded
}

_create_session_windows() {
  local name="$1" dir="$2"

  tmux new-session -d -s "$name" -c "$dir" -n "code"
  tmux send-keys -t "$name:code" "nvim" Enter

  tmux new-window -t "$name" -n "ai" -c "$dir"
  if command -v claude &>/dev/null; then
    tmux send-keys -t "$name:ai" "claude" Enter
  fi

  tmux new-window -t "$name" -n "term" -c "$dir"

  tmux select-window -t "$name:code"
}

# IDE layout: one window with panes —
#   top-left  : nvim (large)
#   top-right : claude (~30% width)
#   bottom    : term + one pane per .trun config entry (~30% height)
# Each pane is tagged with @layout-name so `tlayout` can convert back to
# the windows layout without losing track of which pane is which.
_create_session_ide() {
  local name="$1" dir="$2"
  local trun_file="$dir/.trun"

  tmux new-session -d -s "$name" -c "$dir" -n "ide"
  tmux set-option -w -t "$name:ide" pane-border-status top

  local top_left bottom_strip top_right
  top_left=$(tmux list-panes -t "$name:ide" -F '#{pane_id}' | head -1)

  bottom_strip=$(tmux split-window -v -l '30%' -t "$top_left" -c "$dir" -P -F '#{pane_id}')
  top_right=$(tmux split-window -h -l '30%' -t "$top_left" -c "$dir" -P -F '#{pane_id}')

  tmux set-option -p -t "$top_left"     @layout-name code
  tmux set-option -p -t "$top_right"    @layout-name ai
  tmux set-option -p -t "$bottom_strip" @layout-name term

  tmux send-keys -t "$top_left" "nvim" Enter
  if command -v claude &>/dev/null; then
    tmux send-keys -t "$top_right" "claude" Enter
  fi

  if [[ -f "$trun_file" ]]; then
    local prev="$bottom_strip"
    local line label cmd new_pane
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      [[ "$line" =~ ^[[:space:]]*([^:[:space:]]+)[[:space:]]*:[[:space:]]*(.*)$ ]] || continue
      label="${BASH_REMATCH[1]}"
      cmd="${BASH_REMATCH[2]}"
      [[ -z "$cmd" ]] && continue
      new_pane=$(tmux split-window -h -t "$prev" -c "$dir" -P -F '#{pane_id}')
      tmux set-option -p -t "$new_pane" @layout-name "run-$label"
      tmux send-keys -t "$new_pane" "$cmd" Enter
      prev="$new_pane"
    done < "$trun_file"
  fi

  tmux select-pane -t "$top_left"
}

_pick_layout() {
  if [[ -n "${TP_LAYOUT:-}" ]]; then
    printf '%s\n' "$TP_LAYOUT"
    return 0
  fi
  printf 'windows\nide\n' | fzf \
    --prompt='layout> ' \
    --height=40% \
    --border=rounded \
    --no-multi \
    --header='enter: create session with this layout' \
    --preview-window='right:60%:wrap' \
    --preview='case {} in
                 windows) printf "windows layout — current default\n\n  [code]   [ai]   [term]\n\nThree separate windows.\nSwitch with prefix+1/2/3 or prefix+e/i/o.\nrun-* windows added on demand by trun.\n" ;;
                 ide)     printf "ide layout — single window with panes\n\n  +-----------+--------+\n  |           |        |\n  |   nvim    |   ai   |\n  |           |        |\n  +-----------+--------+\n  |  term  |  run-... |\n  +--------------------+\n\nBottom strip = term + one pane\nper .trun config entry.\nUse prefix+z to zoom a pane.\n" ;;
               esac'
}

_attach() {
  local name="$1"
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "=$name"
  else
    tmux attach-session -t "=$name"
  fi
}

main() {
  # Internal: used by fzf reload binding.
  if [[ "${1:-}" == "--__list" ]]; then
    _list_rows
    exit 0
  fi

  # Internal: used by fzf ctrl-x binding. Kills session by exact name.
  if [[ "${1:-}" == "--__kill" ]]; then
    shift
    [[ -n "${1:-}" ]] && tmux kill-session -t "=$1" 2>/dev/null || true
    exit 0
  fi

  local target=""
  local name=""

  case "${1:-}" in
    "")
      local sel status path display
      sel=$(_pick_row || true)
      [[ -z "$sel" ]] && exit 0
      IFS=$'\t' read -r status name path display <<< "$sel"
      if [[ "$status" == "RUNNING" && -z "$path" ]]; then
        _attach "$name"
        exit 0
      fi
      target="$path"
      ;;
    ".") target="$PWD" ;;
    *)   target="$1" ;;
  esac

  target=$(cd -- "$target" && pwd)
  name=$(_session_name "$target")

  if ! tmux has-session -t "=$name" 2>/dev/null; then
    local layout
    layout=$(_pick_layout || true)
    [[ -z "$layout" ]] && exit 0
    case "$layout" in
      ide)     _create_session_ide     "$name" "$target" ;;
      windows) _create_session_windows "$name" "$target" ;;
      *)
        echo "tp: unknown layout '$layout'" >&2
        exit 1
        ;;
    esac
  fi

  _attach "$name"
}

main "$@"
